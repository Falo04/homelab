# Homelab compose management (Traefik + Vault)
# Usage: `just <recipe>` — run `just` with no args to list recipes

# docker compose invocation used by every recipe
dc := "docker compose -f docker-compose.yml --env-file .env"

# Default recipe: show the available commands
default:
    @just --list

# Start the stack in the background
up:
    {{dc}} up -d

# Stop and remove the stack
down:
    {{dc}} down

# Pull the latest images
pull:
    {{dc}} pull

# Pull latest images and recreate the stack
update: pull up

# Follow logs (optionally for a single service, e.g. `just logs vault`)
logs service="":
    {{dc}} logs -f --tail=100 {{service}}

# Render the fully-resolved compose config
config:
    {{dc}} config

# Validate the compose file
lint:
    {{dc}} config -q && echo "ok"

# Run a one-off command in a service, e.g. `just exec vault sh`
exec service +cmd:
    {{dc}} exec {{service}} {{cmd}}
